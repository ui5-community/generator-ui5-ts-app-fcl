{
  "name": "<%= appId %>",
  "version": "1.0.0",
  "description": "UI5 Application: <%= namespace %>",
  "author": "<%= author %>",
  "license": "Apache-2.0",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "scripts": {
    "build": "ui5 build --clean-dest",
    "build:opt": "ui5 build self-contained --clean-dest --all",
    "start": "ui5 serve --port 8080 -o index.html",
    "start-cdn": "ui5 serve --port 8080 -o index-cdn.html",
    "start:dist": "npm start -- --config ui5-dist.yaml",
    "start:dist-cdn": "npm run start-cdn -- --config ui5-dist.yaml",
    "ts-typecheck": "tsc --noEmit",
    "lint": "eslint webapp",
    "deploy": "npm run build && fiori deploy --config ui5-deploy.yaml && rimraf archive.zip"
  },
  "devDependencies": {
    "@sap/ux-ui5-tooling": "^1.27.0",
    "<%= tstypes %>": "<%= tstypesVersion %>",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@ui5/cli": "^4.0.57",
    "eslint": "^10.5.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "ui5-middleware-livereload": "^3.3.1",
    "ui5-tooling-transpile": "^3.11.3"
  }
}
